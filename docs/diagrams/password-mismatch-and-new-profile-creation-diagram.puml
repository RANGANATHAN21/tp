@startuml profile-manager-new-profile-sequence
  skinparam sequenceArrowThickness 2
  skinparam sequenceParticipantBorderColor #333333

  participant TradeLog
  participant ProfileManager
  participant "Storage\n(trades.txt)" as Storage1
  participant "Storage\n(trades_1.txt)" as Storage2

  TradeLog -> ProfileManager : new ProfileManager(baseDir, baseName, ui)
  activate ProfileManager

  ProfileManager -> ProfileManager : check File(baseDir/baseName.txt).exists()
  note right : files exist → use\nload prompt

  ProfileManager -> ProfileManager : ui.readPassword(\n"Enter password to load\nyour profile (or create\na new one):")

  ProfileManager -> ProfileManager : tryLoadExistingProfile(baseDir, baseName, password, ui)
  activate ProfileManager

  ProfileManager -> Storage1 : new Storage("trades.txt")
  activate Storage1
  ProfileManager -> Storage1 : setPassword(password)
  ProfileManager -> Storage1 : loadTrades()
  Storage1 --> ProfileManager : TradeLogException (hash mismatch)
  deactivate Storage1

  ProfileManager --> ProfileManager : no further files → return false
  deactivate ProfileManager

  ProfileManager -> ProfileManager : ui.readLine(\n"No profile found for the entered\npassword. Create a new\nprofile? (yes/no):")
  note right : user answers "yes"

  ProfileManager -> ProfileManager : createNewProfile(baseDir, baseName, password, ui,\n"Creating new profile...")
  activate ProfileManager

  ProfileManager -> ProfileManager : findNextAvailablePath(baseDir, baseName)\n→ "trades_1.txt"
  ProfileManager -> Storage2 : new Storage("trades_1.txt")
  activate Storage2
  ProfileManager -> Storage2 : setPassword(password)
  ProfileManager --> ProfileManager : loadedTrades = new TradeList()
  deactivate ProfileManager
  deactivate Storage2

  ProfileManager --> TradeLog
  deactivate ProfileManager

  TradeLog -> ProfileManager : getActiveStorage()
  TradeLog -> ProfileManager : getLoadedTrades()
  @enduml